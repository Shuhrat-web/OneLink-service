generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CaptchaMode {
  off
  always
}

enum Platform {
  ios
  android
  web
}

enum DeviceType {
  mobile
  tablet
  desktop
  bot
  unknown
}

enum UserRole {
  admin
  user
}

model SmartLink {
  id             String      @id @default(cuid())
  title          String
  description    String?
  slug           String      @unique
  iosUrl         String
  androidUrl     String
  webUrl         String
  deepLinkUrl    String?
  isActive       Boolean     @default(true)
  expiresAt      DateTime?
  maxClicks      Int?
  captchaEnabled Boolean     @default(false)
  captchaMode    CaptchaMode @default(off)
  ownerId        String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  owner      User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  clickEvents ClickEvent[]

  @@index([slug])
  @@index([ownerId])
  @@index([isActive])
  @@index([expiresAt])
}

model ClickEvent {
  id             String     @id @default(cuid())
  smartLinkId    String
  clickedAt      DateTime   @default(now())
  platform       Platform
  os             String?
  browser        String?
  deviceType     DeviceType @default(unknown)
  userAgent      String?
  referrer       String?
  country        String?
  ipHash         String?
  isUnique       Boolean    @default(false)
  captchaPassed  Boolean    @default(false)
  redirectTarget String

  smartLink SmartLink @relation(fields: [smartLinkId], references: [id], onDelete: Cascade)

  @@index([smartLinkId, clickedAt])
  @@index([smartLinkId, platform])
  @@index([ipHash, clickedAt])
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         UserRole  @default(user)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  smartLinks SmartLink[]
}
